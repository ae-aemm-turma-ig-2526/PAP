<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<title>Auto Prime Stand</title>

<style>
:root {
    --dark: #020617;
    --accent: #f97316;
    --bg: #f8fafc;
}

* { box-sizing: border-box; }

html, body { height: 100%; }
 
body {
    margin: 0;
    font-family: "Segoe UI", Arial, sans-serif;
    background-color: var(--bg);
    display: flex;
    flex-direction: column;
}

/* HEADER */
header {
    background: linear-gradient(135deg, #020617, #0f172a);
    color: white;
    padding: 15px 30px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 12px;
}

.logo img { height: 80px; } /* LOGO MAIOR */

.logo span {
    font-size: 1.4em;
    font-weight: bold;
}

/* NAV */
nav {
    background-color: var(--dark);
    display: flex;
    justify-content: center;
    gap: 35px;
    padding: 12px;
}

nav a {
    color: white;
    font-weight: 600;
    cursor: pointer;
}

nav a:hover { color: var(--accent); }

/* MAIN */
main { flex: 1; }

/* SECTIONS */
section {
    display: none;
    padding: 60px 12%;
}

section.active { display: block; }

/* CARROS */
.carros {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 30px;
}

.carro {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.12);
}

.carro img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.carro .info {
    padding: 15px;
}

.carro h3 { margin: 0 0 5px; }

.preco { color: var(--accent); font-weight: bold; }

.carro p { margin: 5px 0; }

/* FORM */
form {
    max-width: 500px;
    margin: auto;
}

input, textarea {
    width: 100%;
    padding: 14px;
    margin: 12px 0;
    border-radius: 8px;
    border: 1px solid #ccc;
}

button {
    width: 100%;
    padding: 12px;
    background-color: var(--accent);
    border: none;
    color: white;
    border-radius: 8px;
    cursor: pointer;
}

button:hover { background-color: #ea580c; }

/* ADMIN */
.card {
    background: white;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.12);
}

.mensagem {
    border-bottom: 1px solid #ddd;
    padding: 15px 0;
}

/* FOOTER */
footer {
    background-color: var(--dark);
    color: white;
    text-align: center;
    padding: 20px;
    font-weight: 600;
}
</style>
</head>

<body>

<header>
    <div class="logo">
        <img src="logo.png" alt="Logo">
        <span>Auto Prime Stand</span>
    </div>
</header>

<nav>
    <a onclick="mostrar('inicio')">Início</a>
    <a onclick="mostrar('carros')">Carros</a>
    <a onclick="mostrar('sobre')">Sobre</a>
    <a onclick="mostrar('contacto')">Contacto</a>
    <a onclick="mostrar('login')">Admin</a>
</nav>

<main>

<section id="inicio" class="active">
    <div class="card">
        <h2>Bem-vindo à Auto Prime Stand</h2>
        <p>Stand automóvel com viaturas certificadas, qualidade e garantia.</p>
    </div>
</section>

<section id="carros">
    <h2>Viaturas Disponíveis</h2>
    <div class="carros" id="listaCarros"></div>
</section>

<section id="sobre">
    <div class="card">
        <h2>Sobre a Empresa</h2>
        <p>
            A Auto Prime Stand é especializada na venda de veículos
            de alta qualidade, garantindo transparência, confiança e satisfação
            total aos clientes.
        </p>
    </div>
</section>

<section id="contacto">
    <h2>Contacto</h2>
    <form onsubmit="guardar(event)">
        <input id="nome" placeholder="Nome" required>
        <input id="email" type="email" placeholder="Email" required>
        <textarea id="mensagem" placeholder="Mensagem" required></textarea>
        <button type="submit">Enviar</button>
    </form>
</section>

<section id="login">
    <div class="card">
        <h2>Área Administrativa</h2>
        <input id="password" type="password" placeholder="Password">
        <button onclick="login()">Entrar</button>
    </div>
</section>

<section id="admin">
    <div class="card">
        <h2>Mensagens Recebidas</h2>
        <div id="listaMensagens"></div>
        <button onclick="limpar()">Apagar Tudo</button>
    </div>
</section>

<section id="adminCarros">
    <div class="card">
        <h2>Gerir Carros</h2>
        <h3>Adicionar Novo Carro</h3>
        <input id="marca" placeholder="Marca (ex: BMW)">
        <input id="modelo" placeholder="Modelo (ex: Série 3)">
        <input id="ano" placeholder="Ano (ex: 2021)">
        <input id="km" placeholder="Km (ex: 150000)">
        <input id="combustivel" placeholder="Combustível (ex: Gasolina)">
        <input id="precoCarro" placeholder="Preço (ex: 25000)">
        <input id="imagem" placeholder="Imagem (ex: bmw.png)">
        <textarea id="descricao" placeholder="Descrição"></textarea>
        <button onclick="adicionarCarro()">Adicionar Carro</button>
        <hr>
        <h3>Lista de Carros (Admin)</h3>
        <div id="listaCarrosAdmin"></div>
    </div>
</section>

</main>

<footer>
    Auto Prime Stand © 2024
</footer>

<script>
// Inicializar carros se não existirem
const initialCars = [
    {marca: 'BMW', modelo: 'Série 3', ano: '2021', km: '150000', combustivel: 'Gasolina', preco: '25000', imagem: 'bmw.png', descricao: ''},
    {marca: 'Audi', modelo: 'A4', ano: '2020', km: '130000', combustivel: 'Diesel', preco: '23500', imagem: 'audi.png', descricao: ''},
    {marca: 'Mercedes', modelo: 'Classe C', ano: '2019', km: '110000', combustivel: 'Gasolina', preco: '28000', imagem: 'mercedes.png', descricao: ''},
    {marca: 'Toyota', modelo: 'Corolla', ano: '2022', km: '50000', combustivel: 'Híbrido', preco: '22500', imagem: 'corolla.png', descricao: ''},
    {marca: 'Honda', modelo: 'Civic', ano: '2021', km: '60000', combustivel: 'Gasolina', preco: '21000', imagem: 'civic.png', descricao: ''}
];

if (!localStorage.getItem('carros')) {
    localStorage.setItem('carros', JSON.stringify(initialCars));
}

function mostrar(id) {
    document.querySelectorAll("section").forEach(s => s.classList.remove("active"));
    document.getElementById(id).classList.add("active");
}

function carregarCarros() {
    let carros = JSON.parse(localStorage.getItem('carros')) || [];
    let html = '';
    carros.forEach(c => {
        html += `
        <div class="carro">
            <img src="${c.imagem}">
            <div class="info">
                <h3>${c.marca} ${c.modelo}</h3>
                <p>Ano: ${c.ano} | ${c.km.toLocaleString()} km | ${c.combustivel}</p>
                ${c.descricao ? `<p>${c.descricao}</p>` : ''}
                <p class="preco">${parseFloat(c.preco).toLocaleString()}€</p>
            </div>
        </div>`;
    });
    document.getElementById('listaCarros').innerHTML = html || '<p>Sem carros disponíveis.</p>';
    
    // Também carrega para admin
    let adminHtml = '';
    carros.forEach((c, index) => {
        adminHtml += `<div class="mensagem"><strong>${c.marca} ${c.modelo}</strong> - ${c.preco}€ <button onclick="removerCarro(${index})" style="background:#ef4444;color:white;border:none;padding:5px;border-radius:4px;cursor:pointer;float:right;">Remover</button></div>`;
    });
    document.getElementById('listaCarrosAdmin').innerHTML = adminHtml || 'Sem carros.';
}

function adicionarCarro() {
    let carros = JSON.parse(localStorage.getItem('carros')) || [];
    let novoCarro = {
        marca: document.getElementById('marca').value,
        modelo: document.getElementById('modelo').value,
        ano: document.getElementById('ano').value,
        km: document.getElementById('km').value,
        combustivel: document.getElementById('combustivel').value,
        preco: document.getElementById('precoCarro').value,
        imagem: document.getElementById('imagem').value,
        descricao: document.getElementById('descricao').value
    };
    carros.push(novoCarro);
    localStorage.setItem('carros', JSON.stringify(carros));
    
    // Limpar form
    document.querySelectorAll('#adminCarros input, #adminCarros textarea').forEach(el => el.value = '');
    
    carregarCarros();
    alert('Carro adicionado!');
}

function removerCarro(index) {
    let carros = JSON.parse(localStorage.getItem('carros')) || [];
    carros.splice(index, 1);
    localStorage.setItem('carros', JSON.stringify(carros));
    carregarCarros();
}

function guardar(e) {
    e.preventDefault();
    let lista = JSON.parse(localStorage.getItem("contactos")) || [];
    lista.push({
        nome: document.getElementById('nome').value,
        email: document.getElementById('email').value,
        mensagem: document.getElementById('mensagem').value,
        data: new Date().toLocaleString('pt-PT')
    });
    localStorage.setItem("contactos", JSON.stringify(lista));
    alert("Mensagem enviada!");
    e.target.reset();
    mostrar("inicio");
}

function login() {
    if (document.getElementById('password').value === "Mateus244+") {
        carregarMensagens();
        carregarCarros();
        mostrar("adminCarros");
    } else {
        alert("Password incorreta");
    }
}

function carregarMensagens() {
    let lista = JSON.parse(localStorage.getItem("contactos")) || [];
    let html = "";
    lista.forEach(m => {
        html += `
        <div class="mensagem">
            <strong>${m.nome}</strong> (${m.data || 'Sem data'})<br>
            ${m.email}<br>
            ${m.mensagem}
        </div>`;
    });
    document.getElementById('listaMensagens').innerHTML = html || "Sem mensagens.";
}

function limpar() {
    if (confirm('Apagar todas as mensagens?')) {
        localStorage.removeItem("contactos");
        carregarMensagens();
    }
}

// Inicializar
carregarCarros();
</script>

</body>
</html>
